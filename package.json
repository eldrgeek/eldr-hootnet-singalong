{
  "name": "hootnet-singalong",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:server": "cd server && node index.js",
    "test": "cd server && npm test",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:server-api": "npx playwright test e2e/server-api.spec.ts --project=chromium",
    "test:e2e:ui": "npx playwright test e2e/ui-flow.spec.ts --project=chromium",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "livekit-client": "^2.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
